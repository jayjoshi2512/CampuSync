# ============================================
# NODE
# ============================================
NODE_ENV=development
PORT=5000
APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:5000

# ============================================
# DATABASE (MongoDB)
# Local:      mongodb://127.0.0.1:27017/alumni_db
# Atlas:      mongodb+srv://<user>:<pass>@cluster.mongodb.net/alumni_db?retryWrites=true&w=majority
# ============================================
MONGODB_URI=mongodb://127.0.0.1:27017/alumni_db

# ============================================
# JWT SECRETS (use 64-char random strings in production)
# ============================================
JWT_SECRET_SUPER_ADMIN=local-dev-super-admin-secret-change-me-in-production-64chars!!
JWT_SECRET_ADMIN=local-dev-admin-secret-change-me-in-production-64chars!!!!!!!!
JWT_SECRET_USER=local-dev-user-secret-change-me-in-production-64chars!!!!!!!!!
JWT_SECRET_MAGIC_LINK=local-dev-magic-link-secret-change-me-in-production-64chars!!

# ============================================
# CLOUDINARY
# ============================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================================
# REDIS (Upstash HTTP REST)
# For local dev without Upstash, the app uses
# an in-memory fallback (see config/redis.js)
# ============================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================
# EMAIL
# MAIL_PROVIDER options:
# - smtp (default if SMTP_HOST is set)
# - resend_api (uses HTTPS API, recommended on platforms where SMTP may timeout)
# For local dev, emails are logged to console when SMTP_HOST=localhost
# ============================================
MAIL_PROVIDER=smtp
RESEND_API_KEY=re_NMba49PV_BtKqk27arz2kkaFd6rSYqwE5

# SMTP settings (used when MAIL_PROVIDER=smtp)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=CampuSync
SMTP_FROM_EMAIL=noreply@phygital.local

# Optional SMTP timeout tuning (milliseconds)
SMTP_CONNECTION_TIMEOUT_MS=15000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=20000
SMTP_REJECT_UNAUTHORIZED=false

# ============================================
# RAZORPAY
# ============================================
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
RAZORPAY_PLAN_ID_STARTER=plan_starter_id
RAZORPAY_PLAN_ID_GROWTH=plan_growth_id

# ============================================
# CLOUDFLARE TURNSTILE
# Use test keys for local development:
# Site Key: 1x00000000000000000000AA (always passes)
# Secret: 1x0000000000000000000000000000000AA (always passes)
# ============================================
CLOUDFLARE_TURNSTILE_SECRET=1x0000000000000000000000000000000AA

# ============================================
# SUPER ADMIN SEED EMAIL
# ============================================
SUPER_ADMIN_EMAIL=admin@phygital.local
